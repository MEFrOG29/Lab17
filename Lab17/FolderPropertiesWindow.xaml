<Window x:Class="Lab17.FolderPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab17"
        mc:Ignorable="d"
        Title="FolderPropertiesWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <Image Source="pack://application:,,,/Resources/folder.png" Width="48" Height="48"/>
            <TextBlock Text="{Binding FolderName}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <Separator Margin="0,5"/>
            <TextBlock Text="{Binding FullPath}" TextWrapping="Wrap" Foreground="Gray" Margin="0,5"/>

            <UniformGrid Columns="2" Margin="0,10">
                <TextBlock Text="Файлов: "/>
                <TextBlock Text="{Binding FileCount}" FontWeight="Bold"/>

                <TextBlock Text="Папок: " Margin="0,5,0,0"/>
                <TextBlock Text="{Binding FolderCount}" FontWeight="Bold" Margin="0,5,0,0"/>

                <TextBlock Text="Размер: " Margin="0,5,0,0"/>
                <TextBlock Text="{Binding TotalSizeDisplay}" FontWeight="Bold" Margin="0,5,0,0"/>

                <TextBlock Text="% на диске: " Margin="0,5,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="{Binding PercentOfDrive, StringFormat=\{0:F2\}%}" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ProgressBar Value="{Binding PercentOfDrive}" Width="100" Height="10" Margin="10,0" Maximum="100"/>
                </StackPanel>
            </UniformGrid>

            <TextBlock Text="Топ-5 тяжелых файлов:" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <ListView ItemsSource="{Binding TopFiles}" Height="120">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Размер" DisplayMemberBinding="{Binding SizeStr}" Width="80"/>
                        <GridViewColumn Header="Путь" DisplayMemberBinding="{Binding Path}" Width="280"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>

        <Button Grid.Row="2" Content="OK" Width="80" HorizontalAlignment="Right" Margin="0,10,0,0" Click="Button_Click"/>
    </Grid>
</Window>
