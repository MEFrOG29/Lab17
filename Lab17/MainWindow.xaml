<Window x:Class="Lab17.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lab17.ViewModels"
        Title="Файловый менеджер" Height="450" Width="800">
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="MenuItem_Click"/>
            </MenuItem>
        </Menu>

        <TextBox DockPanel.Dock="Top" 
                 Text="{Binding CurrentPath, UpdateSourceTrigger=LostFocus}" 
                 Margin="5" Padding="3"/>

        <ListView ItemsSource="{Binding Items}" 
                  SelectedItem="{Binding SelectedItem}" 
                  MouseDoubleClick="ListView_MouseDoubleClick"
                  Margin="5">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Копировать" 
                  Command="{Binding CopyItemCommand}" />
                    <MenuItem Header="Вставить" 
                  Command="{Binding PasteItemCommand}" />
                    <MenuItem Header="Сжать в архив"
                  Command="{Binding CompressItemCommand}" />
                    <MenuItem Header="Извлечь из архива"
                  Command="{Binding DecompressItemCommand}" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Тип" Width="40">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Icon}" Width="16" Height="16"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding Name}" Width="250"/>
                    <GridViewColumn Header="Дата изменения" DisplayMemberBinding="{Binding DateModified, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                    <GridViewColumn Header="Размер" DisplayMemberBinding="{Binding Size}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>